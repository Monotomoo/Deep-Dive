# Deep Dive — environment
#
# Copy this file to `.env.local` and fill the two values from your Supabase
# project (Dashboard → Project Settings → API). See SUPABASE.md for the 5-minute
# setup, including the one SQL block to run.
#
# Leave these UNSET (or delete .env.local) to run the app purely locally
# (localStorage only) — the cloud/sign-in layer stays completely inert.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
